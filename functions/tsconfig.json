{
  "compilerOptions": {
    "baseUrl": ".",
    "module": "commonjs",
    "target": "es2020",
    "outDir": "lib",
    "rootDir": "src",
    "skipLibCheck": true,      // Bỏ qua lỗi trong node_modules
    "esModuleInterop": true,
    "strict": true,
    "paths": {"@shared/*": ["src/shared/*"]}
  },
  "include": ["src"],          // CHỈ biên dịch code trong thư mục src của functions
  "exclude": [
    "node_modules"             // CHỈ cần loại bỏ node_modules là đủ
  ]
}